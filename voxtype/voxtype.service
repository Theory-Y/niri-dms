# Launches the wrapper voxtype-with-vocab-list so the Whisper vocabulary comes
# from ~/.config/voxtype/vocabulary.txt. 

[Unit]
Description=Voxtype voice-to-text daemon
Documentation=https://voxtype.io
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.config/voxtype/voxtype-with-vocab-list
Restart=on-failure
RestartSec=5

# Ensure we have access to the display
Environment=XDG_RUNTIME_DIR=%t

[Install]
WantedBy=graphical-session.target
